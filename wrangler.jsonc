{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "taniti-island",
  "compatibility_date": "2026-05-30",
  "observability": {
    "enabled": true
  },
  // Serve all files in the project root as static assets
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
